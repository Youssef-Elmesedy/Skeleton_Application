{
  "Logging": {
    "LogLevel": {
      "Default":              "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire":             "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",

  "JwtSettings": {
    "SecretKey":        "Y0urSup3rS3cr3tK3y!MustBe32CharsMin!!",
    "Issuer":           "SkeletonEcommerceApi",
    "Audience":         "SkeletonEcommerceClients",
    "ExpiresInMinutes": "60"
  },

  "EmailSettings": {
    "Host":     "smtp.gmail.com",
    "Port":     "587",
    "Username": "your-email@gmail.com",
    "Password": "your-app-password",
    "FromName": "Skeleton E-Commerce"
  },

  "AppSettings": {
    "BaseUrl": "https://localhost:7001"
  },

  "RateLimiting": {
    "RequestsPerWindow": "100",
    "WindowSeconds":     "60"
  },

  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName":     "SkeletonEcom:"
  },

  "Hangfire": {
    "DashboardPath": "/hangfire",
    "WorkerCount":   "5"
  },

  "Localization": {
    "DefaultCulture":    "en",
    "SupportedCultures": [ "en", "ar" ]
  },

  "Stripe": {
    "SecretKey":      "sk_test_YOUR_STRIPE_KEY",
    "WebhookSecret":  "whsec_YOUR_WEBHOOK_SECRET",
    "PublishableKey": "pk_test_YOUR_PUBLISHABLE_KEY"
  },

  "Fawry": {
    "MerchantCode": "YOUR_FAWRY_MERCHANT_CODE",
    "SecurityKey":  "YOUR_FAWRY_SECURITY_KEY",
    "BaseUrl":      "https://atfawry.fawrystaging.com"
  }
}
